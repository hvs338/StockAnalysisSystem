# Copy to .env and fill in your own values:  Copy-Item .env.example .env
# .env is gitignored — never commit real keys. Optional vars show their default; omit to accept it.

# ── Schwab API (required) ─────────────────────────────────────────────
# Create an app under the Individual Trader API at https://developer.schwab.com
SCHWAB_CLIENT_ID=your_schwab_app_key
SCHWAB_CLIENT_SECRET=your_schwab_app_secret
# Must exactly match the callback registered on the Schwab app (HTTPS loopback).
SCHWAB_CALLBACK_URL=https://127.0.0.1
# Where the OAuth refresh token is persisted (relative paths resolve to the repo root).
TOKEN_PATH=token.json

# ── Email delivery via Gmail SMTP (required) ──────────────────────────
# Generate an app password (not your account password) at https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
DIGEST_TO=recipient@example.com

# ── Digest sections (optional; 1=on, 0=off) ───────────────────────────
INCLUDE_MOVERS=1
INCLUDE_POSITIONS=1
INCLUDE_FORECAST=1
# Schwab /movers index: $SPX, $DJI, $COMPX, NYSE, NASDAQ, OTCBB, INDEX_ALL, EQUITY_ALL
MOVERS_INDEX=$SPX
MOVERS_COUNT_PER_SIDE=5

# ── Kronos forecasting (optional; runs on the GPU via kronos_runner.py) ─
# device: auto|cuda|cpu   model: auto|<HuggingFace id>  (auto → Kronos-base on GPU, small on CPU)
KRONOS_DEVICE=auto
KRONOS_MODEL=auto
KRONOS_SAMPLES=25
KRONOS_TEMPERATURE=1.0
KRONOS_TOP_P=0.9

# ── AI analysis via Amazon Bedrock (optional) ─────────────────────────
# Needs AWS creds (env / shared config / IAM role) + model access in the region.
# Use the cross-region inference-profile id (us./global. prefix), not the bare model id.
ENABLE_ANALYSIS=1
BEDROCK_MODEL=us.amazon.nova-pro-v1:0
AWS_REGION=us-west-2
ANALYSIS_MAX_TOKENS=4096
# How many of the day's top movers (by |% change|) to analyze. Each is one Bedrock call.
ANALYSIS_COUNT=5

# ── News fed into the analyst (optional) ──────────────────────────────
# Free API key at https://finnhub.io/register . Without it, news is silently skipped.
FINNHUB_API_KEY=your_finnhub_api_key
ENABLE_NEWS=1
NEWS_LOOKBACK_DAYS=5
NEWS_MAX_ITEMS=6
# Sources ranked first when present (case-insensitive substring); everything else still included.
NEWS_PREFERRED_SOURCES=Yahoo,MarketWatch,Reuters,Barron,CNBC
